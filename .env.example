# General
COMPOSE_PROJECT_NAME=pa
LOG_LEVEL=INFO

# Postgres (shared)
POSTGRES_USER=pa
POSTGRES_PASSWORD=pa_dev_only_change_me
POSTGRES_DB=pa

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_ADMIN_TOKEN=dev_admin_token_change_me
MODEL_SERVER_URL=http://model-server:8080/invocations

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=REPLACE_WITH_FERNET_KEY
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin_dev_only

# Grafana
GF_SECURITY_ADMIN_PASSWORD=grafana_dev_only

# Mailtrap (email notifications for model runs, reports, and Prometheus alerts)
# Sign up at https://mailtrap.io → Inboxes → SMTP Settings → copy credentials
MAILTRAP_USER=your_mailtrap_username
MAILTRAP_PASS=your_mailtrap_password
MAILTRAP_FROM=pa-detector@example.com
MAILTRAP_TO=your@email.com

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=gemma3:4b
