# General
COMPOSE_PROJECT_NAME=pa
LOG_LEVEL=INFO

# Postgres (shared)
POSTGRES_USER=pa
POSTGRES_PASSWORD=pa_dev_only_change_me
POSTGRES_DB=pa

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_ADMIN_TOKEN=dev_admin_token_change_me
