name: pa-detector
conda_env: conda.yaml
entry_points:
  train:
    parameters:
      epochs:     { type: int,   default: 1 }
      lr:         { type: float, default: 2.0e-5 }
      batch_size: { type: int,   default: 16 }
      device:     { type: str,   default: "cpu" }
      data_path:  { type: str,   default: "data/processed/train.parquet" }
      val_path:   { type: str,   default: "data/processed/val.parquet" }
    command: >
      python -m src.train
      --epochs {epochs}
      --lr {lr}
      --batch-size {batch_size}
      --device {device}
      --data-path {data_path}
      --val-path {val_path}
  evaluate:
    command: "python -m src.evaluate"
