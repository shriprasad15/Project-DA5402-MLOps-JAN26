# Copy to docker-compose.override.yml locally for hot-reload.
services:
  backend:
    build: { context: ./backend, target: dev }
    command: uvicorn backend.app.main:app --host 0.0.0.0 --port 8000 --reload
    volumes: ["./backend:/app/backend"]
  frontend:
    build: { context: ./frontend, target: dev }
    command: npm run dev
    volumes: ["./frontend:/app/frontend", "/app/frontend/node_modules"]
    ports: ["3000:3000"]
